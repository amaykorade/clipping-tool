{
  "name": "kllivo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "worker": "node --env-file=.env --require tsx/cjs src/worker/transcriptionWorker.ts",
    "worker:transcribe": "WORKER_TYPE=transcribe node --env-file=.env --require tsx/cjs src/worker/transcriptionWorker.ts",
    "worker:render": "WORKER_TYPE=render node --env-file=.env --require tsx/cjs src/worker/transcriptionWorker.ts",
    "postinstall": "prisma generate",
    "generate-carousels": "tsx scripts/generate-carousels.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.993.0",
    "@aws-sdk/s3-request-presigner": "^3.993.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "archiver": "^7.0.1",
    "assemblyai": "^4.22.1",
    "axios": "^1.13.4",
    "bullmq": "^5.67.2",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.9.2",
    "motion": "^12.36.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "openai": "^6.17.0",
    "pg": "^8.18.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tsx": "^4.21.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/archiver": "^7.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.3.0",
    "puppeteer": "^24.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
